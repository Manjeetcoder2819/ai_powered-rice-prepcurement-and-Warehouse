{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
,     "src/components/bags/BagsPage.js", "src/components/dashboard/DashboardPage.js", "src/components/dashboard/DonutChart.js", "src/components/dashboard/StockPieChart.js", "src/components/queue/QueuePage.js", "src/components/reports/ReportsPage.js", "src/components/sms/SMSPage.js", "src/components/ui/OfflineBar.js", "src/components/ui/Sidebar.js", "src/components/ui/Topbar.js", "src/components/vehicles/VehiclesPage.js", "src/components/warehouse/WarehousePage.js", "src/components/weather/WeatherPage.js", "src/lib/api.js", "src/types/index.js"  ],
  "exclude": ["node_modules"]
}
